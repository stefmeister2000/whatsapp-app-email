# Anthropic — https://platform.claude.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Business Cloud API — https://developers.facebook.com
# Meta App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAAG...            # permanent System User token (or temp token for testing)
WHATSAPP_PHONE_NUMBER_ID=123456789012345 # "Phone number ID" from API Setup page
WHATSAPP_VERIFY_TOKEN=pick-any-secret    # you choose this; enter the same value in the webhook config

# Optional
PORT=3000
GRAPH_API_VERSION=v21.0
ESCALATION_WEBHOOK_URL=                  # e.g. a Slack incoming-webhook URL for human handoffs
LOG_CACHE_USAGE=0                        # set to 1 to log prompt-cache hit stats

ADMIN_PASSWORD=choose-a-strong-password   # protects the /admin inbox & leads dashboard
DB_PATH=                                  # optional custom SQLite path (default: ./orvion.db)
